.arrow-button {
    width: 80px;
    height: 80px;
    background-color: #2C2C2C;
    border-radius: 20px;
    justify-content: center;
    align-items: center;
}

.arrow-button:active {
    background-color: #1F1F1F;
}

.arrow-icon {
    width: 40px;
    height: 40px;
    unity-background-scale-mode: scale-to-fit;
}